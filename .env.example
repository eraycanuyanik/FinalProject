# ---- LLM (LM Studio on the HOST machine, OpenAI-compatible API) ----
# From inside Docker containers, the host is reachable as host.docker.internal.
LLM_BASE_URL=http://host.docker.internal:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=google/gemma-4-e4b
LLM_REQUEST_TIMEOUT=120

# ---- Embeddings (sentence-transformers, runs inside backend container) ----
EMBEDDING_MODEL=intfloat/multilingual-e5-large
HF_HOME=/app/hf_cache

# ---- ChromaDB (vector DB container) ----
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ---- Backend ----
BACKEND_PORT=8000
# Comma-separated origins allowed to call the API (the frontend dev server).
CORS_ORIGINS=http://localhost:3000

# ---- Frontend ----
# URL the browser uses to reach the backend (host-side mapping).
NEXT_PUBLIC_API_URL=http://localhost:8000
