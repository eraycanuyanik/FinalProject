# ---- LLM ----
# Çağrılar LiteLLM proxy üzerinden geçer (token + maliyet takibi). LiteLLM de
# host'taki LM Studio'ya yönlendirir. Doğrudan LM Studio için:
#   LLM_BASE_URL=http://host.docker.internal:1234/v1  ve  LLM_API_KEY=lm-studio
LLM_BASE_URL=http://litellm:4000/v1
LLM_API_KEY=sk-anlattim-master
# Hızlı, akıl-yürütmesiz model (varsayılan). Türkçe için daha doğal ama ~2x yavaş
# alternatif: google/gemma-4-e4b
LLM_MODEL=qwen2.5-coder-7b-instruct-mlx
LLM_REQUEST_TIMEOUT=300

# ---- LiteLLM dashboard (http://localhost:4000/ui) ----
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=anlattim

# ---- Embeddings (sentence-transformers, runs inside backend container) ----
EMBEDDING_MODEL=intfloat/multilingual-e5-large
HF_HOME=/app/hf_cache

# ---- ChromaDB (vector DB container) ----
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ---- Backend ----
BACKEND_PORT=8000
# Comma-separated origins allowed to call the API (the frontend dev server).
CORS_ORIGINS=http://localhost:3000

# ---- Frontend ----
# URL the browser uses to reach the backend (host-side mapping).
NEXT_PUBLIC_API_URL=http://localhost:8000
